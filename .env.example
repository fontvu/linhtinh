# Example environment variables for local development
# Copy this file to .env.local and set your own values
# DO NOT commit .env.local to the repository

# Passcode hash for tracker authentication (SHA-256 hash of your chosen passcode)
# Generate with: echo -n "your-passcode" | openssl dgst -sha256
VITE_PASSCODE_HASH=your-sha256-hash-here

# Optional hint for the passcode
VITE_PASSCODE_HINT=your birthday
